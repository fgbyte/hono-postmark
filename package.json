{
  "name": "hono-postmark",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/node": "^22.13.14",
      "@cloudflare/workers-types": "^4.20260317.1",
      "better-auth": "^1.5.5",
      "alchemy": "^0.82.1",
      "vitest": "^3.1.1",
      "@vitest/ui": "^3.1.1",
      "@vitest/coverage-v8": "^3.1.1",
      "jsdom": "^26.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo -F @hono-postmark/infra -F @hono-postmark/db dev db:studio",
    "deploy": "turbo -F @hono-postmark/infra deploy",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @hono-postmark/db db:push",
    "db:studio": "turbo -F @hono-postmark/db db:studio",
    "db:generate": "turbo -F @hono-postmark/db db:generate",
    "db:migrate": "turbo -F @hono-postmark/db db:migrate",
    "open-auth-docs": "open-cli http://localhost:3000/api/auth/reference",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@hono-postmark/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@hono-postmark/config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "^0.19.0",
    "oxlint": "^1.34.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
